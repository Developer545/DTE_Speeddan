PORT=3001
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=tu_password_local
DB_NAME=mi_empresa_db
NODE_ENV=development
JWT_SECRET=cambia_este_secreto_jwt_en_produccion

# SuperAdmin — usa secreto completamente distinto al de los tenants
SUPERADMIN_JWT_SECRET=cambia_este_secreto_superadmin_en_produccion

# Clave AES-256 para cifrar contrasenas de firma y API MH (exactamente 32 caracteres)
ENCRYPTION_KEY=32_caracteres_exactos_aqui_cambia

# Sentry — monitoreo de errores en produccion (dejar vacio para deshabilitar)
# SENTRY_DSN=https://your-dsn@sentry.io/project-id

# Backup automatico
# BACKUP_DIR=../backups
# BACKUP_RETENTION_DAYS=30

# Prisma / Neon (produccion)
DATABASE_URL="postgresql://usuario:password@host.neon.tech/nombre_db?sslmode=require&channel_binding=require"
